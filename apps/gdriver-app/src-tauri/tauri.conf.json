{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "gDriver",
  "version": "0.1.0",
  "identifier": "io.gdriver.app",
  "build": {
    "beforeDevCommand": "pnpm vite",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "gDriver",
        "width": 1024,
        "height": 700,
        "resizable": true,
        "center": true,
        "decorations": true,
        "visible": true,
        "closable": true,
        "backgroundColor": "#1e1e2e"
      }
    ],
    "trayIcon": null
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libgtk-3-0 (>= 3.24)",
          "libfuse3-3",
          "python3",
          "python3-gi",
          "gir1.2-nautilus-4.0"
        ],
        "section": "net",
        "priority": "optional",
        "files": {
          "/usr/lib/gdriver/postinst": "../../../packaging/linux/deb/postinst",
          "/usr/lib/gdriver/postrm": "../../../packaging/linux/deb/postrm"
        }
      },
      "rpm": {
        "depends": [
          "webkit2gtk4.1",
          "gtk3 >= 3.24",
          "fuse3",
          "python3",
          "python3-gobject",
          "nautilus-python"
        ],
        "epoch": 0,
        "release": "1"
      },
      "appimage": {
        "bundleMediaFramework": true
      }
    },
    "windows": {
      "nsis": {
        "installMode": "both",
        "displayLanguageSelector": false,
        "installerIcon": "icons/icon.ico",
        "licenseFile": "../../LICENSE",
        "languages": ["English", "SimpChinese"],
        "template": "../../../packaging/windows/nsis/installer.nsi"
      }
    },
    "macOS": {
      "minimumSystemVersion": "12.0",
      "dmg": {
        "windowSize": {
          "width": 480,
          "height": 360
        },
        "appPosition": {
          "x": 160,
          "y": 160
        },
        "applicationFolderPosition": {
          "x": 320,
          "y": 160
        }
      }
    }
  }
}
