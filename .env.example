# Google OAuth 2.0 credentials
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_client_id_here
GOOGLE_CLIENT_SECRET=your_client_secret_here

# SQLite database path (used by sqlx-cli for offline query checking)
# Linux:   ~/.local/share/gdriver/gdriver.db
# macOS:   ~/Library/Application Support/gdriver/gdriver.db
# Windows: %APPDATA%\gdriver\gdriver.db
DATABASE_URL=sqlite:gdriver.db?mode=rwc

# Optional: override log level (default: info)
RUST_LOG=gdriver_daemon=debug,gdriver_sync=debug
